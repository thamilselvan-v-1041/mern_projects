# Replicate API Token - get free credits at replicate.com
REPLICATE_API_TOKEN=your_replicate_token_here

# Suno-style HTTP API (e.g. sunoapi.org). Set SUNO_API_BASE if your provider differs.
SUNO_API_KEY=
# Optional; default https://api.sunoapi.org
# SUNO_API_BASE=
# Callback URL required by some providers; use a public URL or their docs default
# SUNO_CALLBACK_URL=

# Google Vertex AI — Veo video generation (service account JSON as a single line or paste in deployment env)
GOOGLE_CLOUD_PROJECT=
# Full service account JSON string (not a file path) for serverless
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Optional; default us-central1
# GOOGLE_CLOUD_LOCATION=
# Optional; default veo-2.0-generate-001
# VEO_MODEL_ID=

# AI text in “AI studio” via Groq (optional). https://console.groq.com/keys
GROQ_API_KEY=
# Optional; default llama-3.3-70b-versatile (see Groq model list)
# GROQ_TEXT_MODEL=
# Optional; model for “Expand prompt” in AI studio (defaults to GROQ_TEXT_MODEL or llama-3.3-70b-versatile)
# GROQ_PROMPT_MODEL=

# GIF explorer (Giphy) and stock photos (Pexels) — separate timeline layers
# https://developers.giphy.com/dashboard/
GIPHY_API_KEY=
# https://www.pexels.com/api/
PEXELS_API_KEY=
