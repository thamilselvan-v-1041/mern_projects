{
  "name": "libraryman-server",
  "version": "2.0.0",
  "description": "LibraryMan backend - Node.js/Express API with Catalyst Data Store + Auth (AdvancedIO Function)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "USE_MEMORY_STORE=true nodemon index.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "audit": "npm audit --omit=dev"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "uuid": "^9.0.1",
    "zcatalyst-sdk-node": "^3.4.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "store/**/*.js",
      "middleware/**/*.js",
      "validators/**/*.js"
    ]
  }
}
