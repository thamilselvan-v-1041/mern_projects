# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
USE_MEMORY_STORE=true

# Comma-separated allow-list of origins for CORS (production)
# ALLOWED_ORIGINS=https://libraryman-xxxxx.catalystserverless.com

# ─── OAuth — Zoho ─────────────────────────────────────────────────────────
# Register an OAuth client at https://api-console.zoho.com/
# Authorized redirect URI: <your-app-origin>/auth/callback
# Required scope: AaaServer.profile.READ (or finer-grained Zoho APIs you need)
# ZOHO_OAUTH_CLIENT_ID=
# ZOHO_OAUTH_CLIENT_SECRET=

# ─── OAuth — Google ───────────────────────────────────────────────────────
# Register at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <your-app-origin>/auth/callback
# Required scope: openid email profile
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Role mapping ─────────────────────────────────────────────────────────
# Comma-separated emails that should be granted admin on first sign-in.
# Everyone else defaults to member.
# ADMIN_EMAILS=alice@acme.com,bob@acme.com
