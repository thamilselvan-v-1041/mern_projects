# ─── API ──────────────────────────────────────────────────────────────────
# Local dev: leave as /api so Vite's proxy hits http://localhost:3001
# Production: set to your deployed Catalyst AdvancedIO function URL
# VITE_API_BASE=https://libraryman-xxxxx.catalystserverless.com/server/library_api
VITE_API_BASE=/api

# ─── Auth ─────────────────────────────────────────────────────────────────
# Set to "true" during local dev to use the in-browser mock auth (admin/member
# toggle buttons appear on the sign-in screen). NEVER enable this in production.
VITE_USE_MOCK_AUTH=true

# Override only if you self-host the Catalyst SDK
# VITE_CATALYST_SDK_URL=https://static.zohocdn.com/catalyst/sdk/js/4.4.1/catalystWebSDK.js

# ─── OAuth ────────────────────────────────────────────────────────────────
# Zoho/Google OAuth client IDs/secrets live ONLY on the server (server/.env).
# The client receives only the authorize URL + PKCE artifacts at runtime.
# The OAuth callback route is always: <origin>/auth/callback
