# Groq API key for AI analysis (get from https://console.groq.com)
GROQ_API_KEY=your_grok_api_key

# Optional: Alpha Vantage API key for full fundamentals (Market Cap, P/E, EPS, etc.)
# Get free key at https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Optional: OpenAI as fallback
OPENAI_API_KEY=

# Server port
PORT=3001

# Server binds to 0.0.0.0 by default for network access. Override if needed:
# HOST=0.0.0.0

# Client: full API URL when proxy doesn't work (e.g. from another device)
# VITE_API_URL=http://<your-ip>:3001

# Vite proxy target (default 127.0.0.1 works when API runs on same machine)
# VITE_API_HOST=127.0.0.1

# --- Gold / Chennai (Goodreturns via Jina reader) ---
# Direct fetch to goodreturns.in is often Cloudflare-blocked; server uses Jina reader by default.
# If Jina returns HTTP 451 for goodreturns.in, set a Jina API key (Bearer) or rely on direct HTML fetch fallback.
# JINA_API_KEY=
# GOODRETURNS_JINA_API_KEY=
# GOODRETURNS_DISABLE=1
# GOODRETURNS_JINA_PREFIX=https://r.jina.ai/

# --- Auto-trade (Zerodha Kite Connect) ---
# Register app at https://kite.trade/ to get API key & secret
# KITE_API_KEY=your_api_key
# KITE_API_SECRET=your_api_secret
# KITE_ACCESS_TOKEN=  # Regenerate daily via login flow (expires at market close)
# AUTO_TRADE_QUANTITY=1          # Shares per stock (default 1)
# AUTO_TRADE_DRY_RUN=true        # true = no real orders, false = place real orders
# AUTO_TRADE_CRON=true           # Enable daily cron at 9:20 AM IST (Mon-Fri)
