    "start": "npm run build && node server/index.js",
    "kite-login": "node server/kite-login.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "groq-sdk": "^0.5.0",
    "kiteconnect": "^5.1.0",
    "node-cron": "^3.0.3",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "vite": "^7.2.4"
  }
}
